.float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #5c67f5, #7b85f7);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(92, 103, 245, 0.35);
  z-index: 9999;
}

.float-icon {
  font-size: 36rpx;
}

.float-text {
  font-size: 20rpx;
  color: #ffffff;
  margin-top: 4rpx;
}
